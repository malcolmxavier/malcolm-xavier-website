{
  "name": "malcolm-xavier-website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "dev": "SPOTIFY_OFFLINE=1 next dev",
    "dev:online": "next dev -p 3001",
    "build": "next build",
    "build:offline": "SPOTIFY_OFFLINE=1 next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "tokens:build": "node scripts/build-tokens.mjs",
    "resume:docx": "node scripts/build-resume-docx.mjs",
    "resume:pdf": "npm run resume:docx && node scripts/build-resume-pdf.mjs",
    "bullet-bank:docx": "node scripts/build-bullet-bank-docx.mjs",
    "music:refresh": "node scripts/refresh-music-snapshot.mjs",
    "spotify:health": "curl -s http://127.0.0.1:3001/api/spotify/health | python3 -m json.tool",
    "spotify:snapshot": "curl --fail -sS http://127.0.0.1:3001/api/spotify/snapshot -o lib/feeds/_fixtures/spotify-snapshot.json && echo 'Snapshot captured to lib/feeds/_fixtures/spotify-snapshot.json'",
    "films:refresh": "node scripts/refresh-films-snapshot.mjs",
    "films:health": "curl -s http://127.0.0.1:3001/api/letterboxd/health | python3 -m json.tool",
    "films:snapshot": "curl --fail -sS http://127.0.0.1:3001/api/letterboxd/snapshot -o lib/feeds/_fixtures/letterboxd-snapshot.json && echo 'Snapshot captured to lib/feeds/_fixtures/letterboxd-snapshot.json'",
    "prebuild": "npm run tokens:build"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "docx": "^9.6.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
