# ─────────────────────────────────────────────────────────────────
# Environment variable template for malcolm-xavier-website.
#
# Copy this file to `.env.local` and fill in real values:
#     cp .env.example .env.local
#
# `.env.local` is gitignored (via `.env*`) and must NEVER be committed.
# This template carries variable NAMES and guidance only — no secrets.
#
# Scope legend:
#   [local]  needed on your machine to run the refresh scripts / dev:online
#   [vercel] set in the Vercel project dashboard only; not needed locally
# ─────────────────────────────────────────────────────────────────


# ── Spotify Web API — powers /music ──────────────────────────────
# [local] Client Credentials + a long-lived refresh token. Read-only
# access to public playlists; no user-facing OAuth scope. Only needed
# when refreshing the music snapshot (`npm run music:refresh`) or
# running `npm run dev:online`. Plain `npm run dev` forces offline mode
# and renders from the committed snapshot, so these can stay empty for
# ordinary UI work.
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Captured via the /api/spotify/authorize flow (see lib/feeds/spotify.ts).
SPOTIFY_REFRESH_TOKEN=
# The public Spotify username whose playlists render on /music.
SPOTIFY_USER_ID=


# ── TMDB — enriches /films and /television ───────────────────────
# [local] Used at refresh time to add posters, genres, runtime, cast,
# and director to Letterboxd/Serializd entries. Never called at request
# time — the committed fixtures are what production renders from.
# Use the v3 API key (short ~32-hex-char string), NOT the v4 JWT.
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=


# ── MDBList — ratings aggregator for /films and /television ───────
# [local] Sole source of IMDb, Metacritic, Rotten Tomatoes (critic +
# audience), Trakt, and Letterboxd scores, keyed by TMDB or IMDb id.
# Runs at refresh time only, same posture as TMDB.
# Key from https://mdblist.com/preferences
MDBLIST_API_KEY=


# ── Cron commit-back (production only) ────────────────────────────
# [vercel] The scheduled refresh routes in app/api/cron/* fetch fresh
# data, then commit the regenerated fixtures back to the repo via the
# GitHub Contents API. These two are set in the Vercel dashboard and are
# NOT needed for local development. Listed here so the full surface is
# documented in one place.
#
# CRON_SECRET       — Bearer token Vercel injects to authorize cron hits.
# GITHUB_REPO_TOKEN — GitHub PAT with contents:write on this repo, used
#                     to PUT the refreshed fixtures (fires a redeploy).
